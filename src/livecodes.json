;\n    bottom:20px;\n    right:20px;\n    width:260px;\n    background:white;\n    border-radius:10px;\n}\n\n.chat-header {\n    background:#2f4b7c;\n    color:white;\n    padding:10px;\n}\n\n.chat-body {\n    padding:10px;\n    height:150px;\n}\n</style>\n</head>\n\n<body>\n\n<?php if(!isset($_SESSION['user'])): ?>\n\n<!-- LOGIN PAGE -->\n<div class=\"login-container\">\n    <div class=\"login-box\">\n        <h2>🎓 magistr.cspu.uz</h2>\n\n        <?php if(isset($error)) echo \"<p style='color:red'>$error</p>\"; ?>\n\n        <form method=\"POST\">\n            <input type=\"text\" name=\"login\" placeholder=\"Login\" required>\n            <input type=\"password\" name=\"password\" placeholder=\"Parol\" required>\n            <button type=\"submit\">Kirish</button>\n        </form>\n    </div>\n</div>\n\n<?php else: ?>\n\n<!-- DASHBOARD -->\n\n<div class=\"header\">\n    <h2>🎓 magistr.cspu.uz</h2>\n    <div>\n        <?= $_SESSION['user']; ?> |\n        <a href=\"?logout=1\" style=\"color:white;\">Chiqish</a>\n    </div>\n</div>\n\n<div class=\"sidebar\">\n    <ul>\n        <li>Dashboard</li>\n        <li>Hujjatlar</li>\n        <li>Ilmiy ish</li>\n        <li>Chat</li>\n        <li>Kalendar</li>\n        <li>Natijalar</li>\n    </ul>\n</div>\n\n<div class=\"main\">\n\n    <div class=\"cards\">\n        <div class=\"card blue\">Hujjatlar <h2>12</h2></div>\n        <div class=\"card green\">Ilmiy ish <h2>3/5</h2></div>\n        <div class=\"card orange\">Topshiriqlar <h2>5</h2></div>\n        <div class=\"card red\">GPA <h2>3.8</h2></div>\n    </div>\n\n</div>\n\n<div class=\"chat\">\n    <div class=\"chat-header\">Rahbar bilan chat</div>\n    <div class=\"chat-body\">\n        <p><b>Rahbar:</b> Salom</p>\n        <p><b>Siz:</b> Yangi bob tayyor</p>\n    </div>\n</div>\n\n<?php endif; ?>\n\n</body>\n</html>"
