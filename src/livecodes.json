    "content": "<!DOCTYPE html>\n<html lang=\"uz\">\n<head>\n<meta charset=\"UTF-8\">\n<title>magistr.cspu.uz Dashboard</title>\n\n<style>\nbody {\n    margin:0;\n    font-family: \"Segoe UI\", sans-serif;\n    background:#f4f6f9;\n}\n\n/* HEADER */\n.header {\n    height:60px;\n    background:#2f4b7c;\n    color:white;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    padding:0 20px;\n}\n\n.header .right {\n    display:flex;\n    align-items:center;\n    gap:15px;\n}\n\n/* SIDEBAR */\n.sidebar {\n    width:240px;\n    height:100vh;\n    background:#1e3a5f;\n    color:white;\n    position:fixed;\n    top:60px;\n}\n\n.sidebar ul {\n    list-style:none;\n    padding:0;\n}\n\n.sidebar li {\n    padding:15px 20px;\n    cursor:pointer;\n}\n\n.sidebar li:hover {\n    background:#2f4b7c;\n}\n\n/* MAIN */\n.main {\n    margin-left:240px;\n    margin-top:60px;\n    padding:20px;\n}\n\n/* CARDS */\n.cards {\n    display:flex;\n    gap:15px;\n}\n\n.card {\n    flex:1;\n    padding:20px;\n    border-radius:10px;\n    color:white;\n}\n\n.blue {background:#3b82f6;}\n.green {background:#22c55e;}\n.orange {background:#f59e0b;}\n.red {background:#ef4444;}\n\n/* CALENDAR */\n.calendar {\n    background:white;\n    margin-top:20px;\n    padding:20px;\n    border-radius:10px;\n}\n\n.calendar table {\n    width:100%;\n    text-align:center;\n}\n\n.calendar td {\n    padding:10px;\n}\n\n.dot {\n    width:10px;\n    height:10px;\n    border-radius:50%;\n    display:inline-block;\n}\n\n.green-dot {background:green;}\n.yellow-dot {background:orange;}\n.red-dot {background:red;}\n\n/* RIGHT PANEL */\n.right-panel {\n    position:absolute;\n    right:20px;\n    top:120px;\n    width:250px;\n    background:white;\n    padding:15px;\n    border-radius:10px;\n}\n\n/* CHAT */\n.chat {\n    position:fixed;\n    bottom:20px;\n    right:20px;\n    width:260px;\n    background:white;\n    border-radius:10px;\n    overflow:hidden;\n}\n\n.chat-header {\n    background:#2f4b7c;\n    color:white;\n    padding:10px;\n}\n\n.chat-body {\n    padding:10px;\n    height:150px;\n    overflow-y:auto;\n}\n\n.chat-input {\n    display:flex;\n}\n\n.chat-input input {\n    flex:1;\n    padding:10px;\n    border:none;\n}\n\n.chat-input button {\n    background:#3b82f6;\n    color:white;\n    border:none;\n    padding:10px;\n}\n</style>\n</head>\n\n<body>\n\n<!-- HEADER -->\n<div class=\"header\">\n    <h2>🎓 magistr.cspu.uz</h2>\n    <div class=\"right\">\n        🔔\n        <img src=\"https://i.pravatar.cc/40\" style=\"border-radius:50%\">\n        <span>Name</span>\n    </div>\n</div>\n\n<!-- SIDEBAR -->\n<div class=\"sidebar\">\n    <ul>\n        <li> Dashboard</li>\n        <li> Hujjatlar</li>\n        <li> Ilmiy ish</li>\n        <li> Rahbar bilan chat</li>\n        <li> Kalendar reja</li>\n        <li> Natijalar</li>\n        <li> Sozlamalar</li>\n        <li>Davomat</li>\n    </ul>\n</div>\n\n<!-- MAIN -->\n<div class=\"main\">\n\n    <!-- CARDS -->\n    <div class=\"cards\">\n        <div class=\"card blue\">Hujjatlar <h2>12</h2></div>\n        <div class=\"card green\">Ilmiy ish <h2>3/5</h2></div>\n        <div class=\"card orange\">Topshiriqlar <h2>5</h2></div>\n        <div class=\"card red\">GPA <h2>3.8</h2></div>\n    </div>\n</div>\n\n<!-- CHAT -->\n<div class=\"chat\">\n    <div class=\"chat-header\">Rahbar bilan chat</div>\n    <div class=\"chat-body\">\n        <p><b>Rahbar:</b> Salom</p>\n        <p><b>Siz:</b> Yangi bob tayyor</p>\n    </div>\n    <div class=\"chat-input\">\n        <input placeholder=\"Xabar yozing...\">\n        <button>➤</button>\n    </div>\n</div>\n\n</body>\n</html>"
